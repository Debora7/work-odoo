<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="smart_contract_form" model="ir.ui.view">
            <field name="name">smart.contract.form</field>
            <field name="model">smart.contract</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form>
                    <header>

                    </header>

                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Contract Name"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Client" >
                                <label for="partner_id" 
                                    string="Customer" 
                                    invisible="contract_type != 'sale'"/>
                                <label for="partner_id" 
                                    string="Supplier" 
                                    invisible="contract_type != 'purchase'"/>
                                <label for="partner_id" 
                                    string="Partner" 
                                    invisible="contract_type in ('sale', 'purchase')"/>

                                <field name="partner_id"
                                    nolabel="1"
                                    required="1"/>

                                <field name="legal_partner_id" required="1" context="{'default_parent_id': partner_id, 'default_type': 'contact'}" domain="[('parent_id', '=', partner_id),('is_company','=',False)]"/>
                            </group>
                            <group string="Data">
                                <field name="date_start"/>
                                <field name="date_end"/>
                                <field name="signed_date"/>
                            </group>
                        </group>

                        <group>
                            <group string="Template">
                                <field name="template_contract_id"/>
                            </group>
                            <group/>
                        </group>

                        <notebook>
                            <page name="elements_page" string="Articles">
                                <separator string="Articles" colspan="4" />
                                <field name="visible_elements_ids" nolabel='1' readonly="1">
                                    <list>
                                        <field name='name' />
                                        <field name='numar' />
                                        <field name='tip' />
                                    </list>
                                </field>
                                <p class="oe_grey oe_edit_only">
                                    <strong>Variabile disponibile:</strong><br/>
                                    • <code>$\{contract.field\}</code> sau <code>$\{contract.object\}.method()</code> — câmpuri/metode globale ale contractului<br/>
                                    • <code>$\{attrelation.key\}.[field_name]</code> — câmp global din <em>contract.relations</em><br/>
                                    • <code>$\{localrelation\}.key</code> — relație locală (doar acest element)
                                </p>
                            </page>
                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>
</odoo>